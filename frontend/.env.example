# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Plane Project Management
PLANE_URL=http://34.158.192.195
PLANE_API_TOKEN=your_plane_api_token_here
PLANE_WORKSPACE=testgraph
PLANE_PROJECT_ID=SOCIA

# SNS Publishing Hub (Meta Graph API)
META_APP_ID=your_facebook_app_id
META_APP_SECRET=your_facebook_app_secret
# 32자 이상의 랜덤 문자열 (예: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=your_32_char_random_encryption_key_here

# External Service Integration (범용 API Key 인증)
# 외부 서비스에서 X-Api-Key 헤더로 이 값을 보내면 인증됨
# 생성: openssl rand -hex 32
SOCIAL_PULSE_API_KEY=your_api_key_for_external_services

# ──────────────────────────────────────────────────────────────
# 외부 서비스 연동 방법 (예: 0025_CEO, Townin, 등 어떤 서비스든)
#
# 1) 채널 목록 조회:
#    GET  /api/social-pulse/channels?clientSlug=townin
#    Headers: X-Api-Key: {SOCIAL_PULSE_API_KEY}
#
# 2) SNS 발행 (clientSlug + platform으로 자동 채널 매핑):
#    POST /api/social-pulse/publish
#    Headers:
#      X-Api-Key: {SOCIAL_PULSE_API_KEY}
#      X-Caller-App: 0025_ceo          ← 호출 서비스 식별 (선택)
#    Body:
#      { "clientSlug": "townin", "platform": "FACEBOOK", "content": "..." }
#
# 3) 발행 상태 확인:
#    GET  /api/social-pulse/publish/status?postId={postId}
#    GET  /api/social-pulse/publish/status?callerApp=0025_ceo&limit=10
#    Headers: X-Api-Key: {SOCIAL_PULSE_API_KEY}
# ──────────────────────────────────────────────────────────────
